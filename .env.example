# Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_TELEGRAM_ID=your_telegram_id_here

# Telegram Proxy (optional)
# HTTP/HTTPS:  http://login:password@host:port
# SOCKS5:      socks5://login:password@host:port
# SOCKS5+DNS:  socks5h://login:password@host:port
TELEGRAM_PROXY_URL=

# Bitrix24
B24_WEBHOOK_URL=https://your-portal.bitrix24.ru/rest/1/your_token_here/

# LLM provider: "kie" (default, uses Anthropic via Kie.ai proxy) or "deepseek"
LLM_PROVIDER=kie

# Kie.ai (used when LLM_PROVIDER=kie)
KIE_API_KEY=your_kie_api_key_here
KIE_BASE_URL=https://api.kie.ai/claude
KIE_PROXY_URL=

# DeepSeek (used when LLM_PROVIDER=deepseek). Get key from https://platform.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Yandex Metrika — optional. Token from oauth.yandex.ru (metrika:read scope)
METRIKA_OAUTH_TOKEN=
METRIKA_COUNTER_ID=
METRIKA_BASE_URL=https://api-metrika.yandex.net

# Avito API — optional. developers.avito.ru → Мои приложения
# Uses client_credentials flow. AVITO_USER_ID = "Номер профиля".
AVITO_CLIENT_ID=
AVITO_CLIENT_SECRET=
AVITO_USER_ID=

# Database
DATABASE_PATH=./data/bot.sqlite

# Bot settings
LOG_LEVEL=INFO
SESSION_TTL_MINUTES=30
MAX_SESSION_MESSAGES=20

# Circuit breakers — protect against runaway costs
# Level 1: per-request hard ceiling (any one question)
MAX_ITERATIONS=3
MAX_REQUEST_INPUT_TOKENS=80000
MAX_REQUEST_CREDITS=30.0

# Level 3: global daily ceiling across all users
# At Kie.ai exchange (1 cr ≈ $0.005), 5000 cr ≈ $25/day
DAILY_GLOBAL_CREDITS_LIMIT=5000.0

# Dashboard (HTTP-сервис для VK-специалистов и других внешних людей)
# DASHBOARD_ENABLED=0 — выключить полностью
DASHBOARD_ENABLED=1
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8001
DASHBOARD_REFRESH_MINUTES=5
# Опциональный простой токен для доступа: если задан, нужен ?token=... в URL
# или заголовок X-Dashboard-Token. Пустая строка = открыто всем.
DASHBOARD_TOKEN=
